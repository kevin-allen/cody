# Copy to .env and fill in. The real .env is git-ignored.

# Required for the default provider (OpenAI):
OPENAI_API_KEY=

# Optional — only needed for the Anthropic provider:
ANTHROPIC_API_KEY=

# Optional — only needed for the DeepSeek provider (OpenAI-compatible):
DEEPSEEK_API_KEY=
# DEEPSEEK_API_URL=https://api.deepseek.com   # default; override if needed

# Optional — Ollama server URL (default: http://localhost:11434):
# OLLAMA_BASE_URL=http://localhost:11434
